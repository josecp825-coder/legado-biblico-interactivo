                var w = doc.internal.pageSize.getWidth();
                var y = 15;

                doc.setFontSize(12);
                doc.setTextColor(108, 92, 231);
                doc.text('IGLESIA ADVENTISTA CYPRESS HILLS', w / 2, y, { align: 'center' });
