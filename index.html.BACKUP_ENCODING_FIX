        // пњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Р
        // рЯЫ°пњљ¬П ESCUDO ANTI-LOOP DE RECARGA v84
        // Previene congelamientos por recargas infinitas
        // пњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Р
        function puedeRecargar() {
            const COOLDOWN_MS = 15000; // 15 segundos de espera mпњљnima entre recargas
            const ultimaRecarga = parseInt(sessionStorage.getItem('legado_reload_ts') || '0');
            const ahora = Date.now();
            if (ahora - ultimaRecarga < COOLDOWN_MS) {
                console.warn('[ANTI-LOOP] вЫФ Recarga bloqueada пњљ cooldown activo (' + Math.round((COOLDOWN_MS - (ahora - ultimaRecarga)) / 1000) + 's restantes)');
                return false;
            }
            sessionStorage.setItem('legado_reload_ts', ahora.toString());
            return true;
        }

        // рЯФ• RESET NUCLEAR por URL: agendatecnicadigital.com/?reset=1
        if (window.location.search.includes('reset=1')) {
            (async function() {
                if ('serviceWorker' in navigator) {
                    const regs = await navigator.serviceWorker.getRegistrations();
                    await Promise.all(regs.map(function(r){ return r.unregister(); }));
                }
                if ('caches' in window) {
                    const keys = await caches.keys();
                    await Promise.all(keys.map(function(k){ return caches.delete(k); }));
                }
                localStorage.removeItem('legado_v3');
                sessionStorage.clear();
                window.location.replace('./');
            })();
        }

        // пњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Р
        // SISTEMA DE VERSIпњљN EMBEBIDA v247
        // NO depende de fetch/red пњљ comparaciпњљn instantпњљnea
        // Este nпњљmero cambia con cada deploy en index.html
        // пњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Рпњљ¬Р
        const _HTML_VERSION = '373'; // пњљ¬Р CAMBIAR EN CADA DEPLOY

        async function checkVersion() {
            const versionGuardada = localStorage.getItem('legado_v3') || '0';

            // 1. Verificaciпњљn instantпњљnea: пњљel HTML que se cargпњљ es nuevo?
            if (versionGuardada !== '0' && versionGuardada !== _HTML_VERSION) {
                // El index.html actual tiene una versiпњљn DIFERENTE a la guardada
                // вЖТ Limpiar cachпњљ y recargar
                console.log('[VERSION] рЯЖХ HTML v' + _HTML_VERSION + ' vs guardado v' + versionGuardada + ' вЖТ ACTUALIZANDO');
                const msg = document.getElementById('pwa-splash-msg');
                if (msg) msg.textContent = 'Actualizando a v' + _HTML_VERSION + '...';

                try {
                    if ('serviceWorker' in navigator) {
                        const regs = await navigator.serviceWorker.getRegistrations();
                        await Promise.all(regs.map(r => r.unregister()));
                    }
                    if ('caches' in window) {
                        const keys = await caches.keys();
                        await Promise.all(keys.map(k => caches.delete(k)));
                    }
                } catch(e) { console.warn('[VERSION] cleanup error:', e); }

                localStorage.setItem('legado_v3', _HTML_VERSION);
                sessionStorage.removeItem('legado_reload_ts');
                window.location.replace('./?v=' + _HTML_VERSION + '&t=' + Date.now());
                return;
            }

            // 2. Primera vez o versiпњљn correcta вЖТ guardar y confirmar con servidor
            localStorage.setItem('legado_v3', _HTML_VERSION);

            // 3. Verificaciпњљn secundaria con servidor (no bloquea el splash)
            try {
                const res = await fetch('./version.json?nocache=' + Date.now(), {cache:'no-store'});
                const data = await res.json();
                if (data.version !== _HTML_VERSION) {
                    // El servidor tiene una versiпњљn AпњљN mпњљs nueva que este HTML
                    // вЬЕ Guard anti-loop: verificar cooldown antes de recargar
                    if (!puedeRecargar()) {
                        console.warn('[VERSION] вЫФ Recarga secundaria bloqueada por cooldown');
                        window._ocultarSplash();
                        return;
                    }
                    console.log('[VERSION] рЯФД Servidor tiene v' + data.version + ', actualizando...');
                    if ('serviceWorker' in navigator) {
                        const regs = await navigator.serviceWorker.getRegistrations();
                        await Promise.all(regs.map(r => r.unregister()));
                    }
                    if ('caches' in window) {
                        const keys = await caches.keys();
                        await Promise.all(keys.map(k => caches.delete(k)));
                    }
                    localStorage.setItem('legado_v3', data.version);
                    sessionStorage.removeItem('legado_reload_ts');
                    window.location.replace('./?v=' + data.version + '&t=' + Date.now());
                    return;
                }
            } catch (e) {
                console.warn('[VERSION] Sin acceso al servidor (modo offline ok):', e);
            }

            // вЬЕ Todo bien пњљ ocultar splash
            window._ocultarSplash();
        }

        checkVersion();
        window.addEventListener('online', () => checkVersion());

        // вЬЕ Escuchar cuando el Service Worker se actualiza вЖТ recargar pпњљgina
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.addEventListener('message', function(ev) {
                if (ev.data && ev.data.type === 'SW_UPDATED') {
                    console.log('[PWA] Nuevo SW activo:', ev.data.cache, 'вЖТ recargando...');
                    window.location.replace('./?v=sw&t=' + Date.now());
                }
            });
        }

        // вЬЕ Funciпњљn global para forzar actualizaciпњљn manual (botпњљn en la UI)
        window.forzarActualizacion = async function() {
            if (!confirm('рЯФД Actualizar Legado Bпњљblico\n\nSe descargarпњљ el cпњљdigo mпњљs reciente.\nTus datos estпњљn protegidos.\n\nпњљContinuar?')) return;
            try {
                if ('serviceWorker' in navigator) {
                    const regs = await navigator.serviceWorker.getRegistrations();
                    await Promise.all(regs.map(r => r.unregister()));
                }
                if ('caches' in window) {
                    const keys = await caches.keys();
                    await Promise.all(keys.map(k => caches.delete(k)));
                }
                localStorage.removeItem('legado_v3');
            } catch(e) { console.warn(e); }
            window.location.replace('./index.html?nocache=' + Date.now());
        };

    </script>
