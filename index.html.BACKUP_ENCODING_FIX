            mostrarToast('рЯО® Generando tarjeta...');

            // Dimensiones de la tarjeta (formato vertical ~historia de Instagram)
            const W = 1080, H = 1920;
            const canvas = document.createElement('canvas');
            canvas.width = W; canvas.height = H;
            const ctx = canvas.getContext('2d');

            // вФАвФАвФА FONDO DEGRADADO вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА
            const grad = ctx.createLinearGradient(0, 0, W * 0.6, H);
            grad.addColorStop(0,   '#0d0b2e');
            grad.addColorStop(0.35,'#1a0f3c');
            grad.addColorStop(0.7, '#0f1e4a');
            grad.addColorStop(1,   '#080618');
            ctx.fillStyle = grad;
            ctx.fillRect(0, 0, W, H);

            // вФАвФАвФА TEXTURA DE ESTRELLAS (puntos de luz) вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА
            ctx.fillStyle = 'rgba(255,255,255,0.35)';
            for (let i = 0; i < 120; i++) {
                const x = Math.random() * W;
                const y = Math.random() * H * 0.55;
                const r = Math.random() * 1.8 + 0.3;
                ctx.beginPath();
                ctx.arc(x, y, r, 0, Math.PI * 2);
                ctx.fill();
            }

            // вФАвФАвФА BRILLO CENTRAL (resplandor suave) вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА
            const glow = ctx.createRadialGradient(W/2, H*0.38, 0, W/2, H*0.38, W*0.7);
            glow.addColorStop(0,   'rgba(162,155,254,0.18)');
            glow.addColorStop(0.5, 'rgba(108,92,231,0.06)');
            glow.addColorStop(1,   'rgba(0,0,0,0)');
            ctx.fillStyle = glow;
            ctx.fillRect(0, 0, W, H);

            // вФАвФАвФА Lпњљ¬НNEA DECORATIVA SUPERIOR вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА
            const lineGrad = ctx.createLinearGradient(0, 0, W, 0);
            lineGrad.addColorStop(0,   'rgba(253,203,110,0)');
            lineGrad.addColorStop(0.3, 'rgba(253,203,110,0.8)');
            lineGrad.addColorStop(0.7, 'rgba(253,203,110,0.8)');
            lineGrad.addColorStop(1,   'rgba(253,203,110,0)');
            ctx.strokeStyle = lineGrad;
            ctx.lineWidth = 3;
            ctx.beginPath();
            ctx.moveTo(0, 220); ctx.lineTo(W, 220);
            ctx.stroke();

            // вФАвФАвФА FUNCIпњљN DE TEXTO CON SALTO DE Lпњљ¬НNEA вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА
            function wrapText(text, x, y, maxW, lineH) {
                const words = text.split(' ');
                let line = '';
                let curY = y;
                for (let i = 0; i < words.length; i++) {
                    const testLine = line + words[i] + ' ';
                    if (ctx.measureText(testLine).width > maxW && i > 0) {
                        ctx.fillText(line.trim(), x, curY);
                        line = words[i] + ' ';
                        curY += lineH;
                    } else {
                        line = testLine;
                    }
                }
                ctx.fillText(line.trim(), x, curY);
                return curY + lineH;
            }

            // вФАвФАвФА CARGA DEL LOGO Y RENDER FINAL вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА
            function renderConLogo(logoImg) {
                let cursorY = 60;

                // -- CABECERA: Logo --
                if (logoImg) {
                    ctx.save();
                    // Cпњљrculo de fondo del logo
                    ctx.beginPath();
                    // Clip circular: elimina el cuadro blanco del PNG, queda redondo
                    const logoSize = 200;
                    const logoCX = W / 2;
                    const logoCY = cursorY + logoSize / 2;
                    const logoR  = logoSize / 2;
                    ctx.save();
                    ctx.beginPath();
                    ctx.arc(logoCX, logoCY, logoR, 0, Math.PI * 2);
                    ctx.clip();
                    ctx.drawImage(logoImg, logoCX - logoR, cursorY, logoSize, logoSize);
                    ctx.restore();
                    // Borde dorado exterior (dibujado DESPUES del clip)
                    ctx.save();
                    ctx.beginPath();
                    ctx.arc(logoCX, logoCY, logoR + 8, 0, Math.PI * 2);
                    ctx.strokeStyle = 'rgba(253,203,110,0.65)';
                    ctx.lineWidth = 5;
                    ctx.stroke();
                    ctx.beginPath();
                    ctx.arc(logoCX, logoCY, logoR + 20, 0, Math.PI * 2);
                    ctx.strokeStyle = 'rgba(253,203,110,0.15)';
                    ctx.lineWidth = 2;
                    ctx.stroke();
                    ctx.restore();
                    cursorY += logoSize + 36;
                } else {
                    // Fallback: emoji + texto
                    ctx.font = '100px serif';
                    ctx.textAlign = 'center';
                    ctx.fillStyle = '#fdcb6e';
                    ctx.fillText('рЯУЦ', W/2, cursorY + 80);
                    cursorY += 130;
                }

                // -- DEVOCIONAL DEL DIA (sin texto LEGADO BIBLICO, el logo lo representa) --
                ctx.textAlign = 'center';
                ctx.font = 'bold 34px -apple-system, Arial, sans-serif';
                ctx.fillStyle = 'rgba(253,203,110,0.85)';
                ctx.letterSpacing = '8px';
                ctx.fillText('DEVOCIONAL DEL DIA', W/2, cursorY);
                cursorY += 50;

                // -- Lпњљ¬НNEA SEPARADORA --
                ctx.strokeStyle = 'rgba(253,203,110,0.3)';
                ctx.lineWidth = 1.5;
                ctx.beginPath();
                ctx.moveTo(W*0.15, cursorY); ctx.lineTo(W*0.85, cursorY);
                ctx.stroke();
                cursorY += 52;

                // -- пњљ¬НCONO --
                ctx.font = '110px serif';
                ctx.textAlign = 'center';
                ctx.fillStyle = '#fff';
                ctx.fillText(icono, W/2, cursorY + 80);
                cursorY += 130;

                // -- Tпњљ¬НTULO --
                ctx.textAlign = 'center';
                ctx.font = 'bold 58px -apple-system, Arial, sans-serif';
                ctx.fillStyle = '#ffffff';
                const tituloLines = [];
                const titWords = titulo.split(' ');
                let tLine = '';
                titWords.forEach((w, i) => {
                    const test = tLine + (tLine ? ' ' : '') + w;
                    if (ctx.measureText(test).width > W * 0.82 && tLine) {
                        tituloLines.push(tLine);
                        tLine = w;
                    } else tLine = test;
                    if (i === titWords.length - 1) tituloLines.push(tLine);
                });
                tituloLines.forEach((ln, i) => {
                    ctx.fillText(ln, W/2, cursorY + i * 68);
                });
                cursorY += tituloLines.length * 68 + 50;

                // -- RECUADRO VERSпњљ¬НCULO --
                const boxPad = 50;
                const boxX = boxPad;
                const boxW = W - boxPad * 2;
                // Calcular altura del versпњљculo
                ctx.font = 'italic 42px Georgia, serif';
                const versMaxW = boxW - 80;
                let versLines = [];
                const vWords = vers.split(' ');
                let vLine = '';
                vWords.forEach((w, i) => {
                    const test = vLine + (vLine ? ' ' : '') + w;
                    if (ctx.measureText(test).width > versMaxW && vLine) {
                        versLines.push(vLine);
                        vLine = w;
                    } else vLine = test;
                    if (i === vWords.length - 1) versLines.push(vLine);
                });
                const versBoxH = versLines.length * 58 + 40 + 70; // lпњљneas + ref + padding

                // Fondo del recuadro
                ctx.save();
                ctx.beginPath();
                roundRect(ctx, boxX, cursorY, boxW, versBoxH, 28);
                ctx.fillStyle = 'rgba(253,203,110,0.07)';
                ctx.fill();
                ctx.strokeStyle = 'rgba(253,203,110,0.28)';
                ctx.lineWidth = 2.5;
                ctx.stroke();
                ctx.restore();

                // Barra izquierda dorada
                ctx.fillStyle = '#fdcb6e';
                ctx.beginPath();
                roundRect(ctx, boxX + 18, cursorY + 20, 7, versBoxH - 40, 4);
                ctx.fill();

                // Texto versпњљculo (cursiva)
                ctx.textAlign = 'left';
                ctx.font = 'italic 42px Georgia, serif';
                ctx.fillStyle = '#f0f0ff';
                let vY = cursorY + 50;
                versLines.forEach(ln => {
                    ctx.fillText(ln, boxX + 46, vY);
                    vY += 58;
                });

                // Referencia
                ctx.font = 'bold 35px -apple-system, Arial, sans-serif';
                ctx.fillStyle = '#fdcb6e';
                ctx.textAlign = 'left';
                ctx.fillText(ref.replace('пњљ ', ''), boxX + 46, vY + 18);
                cursorY += versBoxH + 50;

                // -- ETIQUETA REFLEXIпњљN --
                ctx.textAlign = 'left';
                ctx.font = 'bold 30px -apple-system, Arial, sans-serif';
                ctx.fillStyle = 'rgba(162,155,254,0.8)';
                ctx.fillText('рЯТ≠  REFLEXIпњљN', 80, cursorY);
                cursorY += 50;

                // Texto reflexiпњљn (recortado si es muy largo)
                const reflexCorta = reflex.length > 400 ? reflex.substring(0, 397) + '...' : reflex;
                ctx.font = '36px -apple-system, Arial, sans-serif';
                ctx.fillStyle = 'rgba(255,255,255,0.72)';
                ctx.textAlign = 'left';
                cursorY = wrapText(reflexCorta, 80, cursorY, W - 160, 52);
                cursorY += 30;

                // -- Lпњљ¬НNEA INFERIOR --
                ctx.strokeStyle = 'rgba(162,155,254,0.3)';
                ctx.lineWidth = 1.5;
                ctx.beginPath();
                ctx.moveTo(W*0.15, cursorY); ctx.lineTo(W*0.85, cursorY);
                ctx.stroke();
                cursorY += 40;

                // -- MARCA DE AGUA / FOOTER --
                ctx.textAlign = 'center';
                ctx.font = 'bold 30px -apple-system, Arial, sans-serif';
                ctx.fillStyle = 'rgba(255,255,255,0.25)';
                ctx.fillText('Descarga la App: Legado Bпњљblico', W/2, H - 80);
                ctx.font = '26px -apple-system, Arial, sans-serif';
                ctx.fillStyle = 'rgba(253,203,110,0.35)';
                ctx.fillText('agendatecnicadigital.com/legado', W/2, H - 42);

                // вФАвФАвФА EXPORTAR Y COMPARTIR вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА
                // NOTA: NO se pasa `text` cuando hay imagen пњљ evita el mensaje doble en WhatsApp
                canvas.toBlob(blob => {
                    if (!blob) { _compartirTextoDevocional(icono, titulo, vers, ref, reflex); return; }
                    const archivo = new File([blob], 'devocional-legado-biblico.png', { type: 'image/png' });
                    if (navigator.share && navigator.canShare && navigator.canShare({ files: [archivo] })) {
                        // Solo imagen пњљ sin campo `text` para evitar contenido duplicado en WhatsApp
                        navigator.share({
                            title: 'Devocional del Dпњљa пњљ Legado Bпњљblico',
                            files: [archivo]
                        }).catch(() => _compartirTextoDevocional(icono, titulo, vers, ref, reflex));
                    } else if (navigator.share) {
                        // Fallback: solo texto si la app no soporta compartir archivos
                        const texto = `${icono} ${titulo}\n\nрЯУЦ ${vers} ${ref}\n\nрЯТ≠ ${reflexCorta}\n\nпњљ Compartido desde Legado Bпњљblico App рЯУ±`;
                        navigator.share({ title: 'Devocional del Dпњљa пњљ Legado Bпњљblico', text: texto }).catch(() => {});
                    } else {
                        // Desktop: descargar la imagen directamente
                        const url = URL.createObjectURL(blob);
                        const a = document.createElement('a');
                        a.href = url; a.download = 'devocional-legado-biblico.png';
                        a.click();
                        URL.revokeObjectURL(url);
                        mostrarToast('вЬЕ Imagen descargada');
                    }
                }, 'image/png');
            }

            // вФАвФАвФА HELPER: redondear rectпњљngulos вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА
            function roundRect(ctx, x, y, w, h, r) {
                ctx.beginPath();
                ctx.moveTo(x + r, y);
                ctx.lineTo(x + w - r, y);
                ctx.quadraticCurveTo(x + w, y, x + w, y + r);
                ctx.lineTo(x + w, y + h - r);
                ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
                ctx.lineTo(x + r, y + h);
                ctx.quadraticCurveTo(x, y + h, x, y + h - r);
                ctx.lineTo(x, y + r);
                ctx.quadraticCurveTo(x, y, x + r, y);
                ctx.closePath();
            }

            // вФАвФАвФА FALLBACK TEXTO вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА
            function _compartirTextoDevocional(ic, tit, v, r2, rx) {
                const msg = `${ic} *DEVOCIONAL DEL Dпњљ¬НA пњљ LEGADO Bпњљ¬НBLICO*\n*${tit}*\n\nрЯУЦ ${v}\n${r2}\n\nрЯТ≠ _${rx}_\n\n_пњљ Compartido desde Legado Bпњљblico App рЯУ±_`;
                if (navigator.share) {
                    navigator.share({ title: 'Devocional del Dпњљa - Legado Bпњљblico', text: msg }).catch(() => {});
                } else {
                    navigator.clipboard?.writeText(msg).then(() => mostrarToast('вЬЕ Devocional copiado'));
                }
            }

            // вФАвФАвФА CARGAR LOGO Y RENDER вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФА
            const logo = new Image();
            logo.crossOrigin = 'anonymous';
            logo.onload  = () => renderConLogo(logo);
            logo.onerror = () => renderConLogo(null); // sin logo pero seguimos
            logo.src = './icon-192.png';
        }

        // === AпњљO Bпњљ¬НBLICO v2 === Ver: _ano_biblico_v2.js ===

