                // Purgar localStorage por completo de basura y cachпњљ antigua
                localStorage.clear();
                sessionStorage.clear();
                
                // Restaurar los datos vitales puros
                Object.keys(_save).forEach(k => localStorage.setItem(k, _save[k]));

                // Forzar reload fпњљsico desde el servidor
